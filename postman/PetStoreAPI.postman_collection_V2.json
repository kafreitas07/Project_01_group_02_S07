        {
          "name": "TC-015 - Verificando método inválido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TC-015 - Método inválido + Header\r",
                  "\r",
                  "pm.test(\"Deve retornar erro de método inválido\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([405, 415, 500]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Não deve retornar sucesso\", function () {\r",
                  "    pm.expect(pm.response.code).to.not.equal(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Resposta deve conter header Content-Type\", function () {\r",
                  "    pm.response.to.have.header(\"Content-Type\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Resposta pode estar em XML\", function () {\r",
                  "    pm.expect(pm.response.text()).to.include(\"<?xml\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
