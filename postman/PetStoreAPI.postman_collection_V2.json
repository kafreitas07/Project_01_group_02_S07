        {
          "name": "TC-014 - Validação de erro para body inválido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TC-014 - Body inválido com retorno em XML\r",
                  "\r",
                  "pm.test(\"API não deve aceitar body inválido\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([415, 500]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Resposta deve ser em XML\", function () {\r",
                  "    pm.expect(pm.response.text()).to.include(\"<?xml\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Resposta deve conter tag de erro\", function () {\r",
                  "    var resposta = pm.response.text();\r",
                  "    pm.expect(resposta).to.include(\"<apiResponse>\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Resposta não deve ser vazia\", function () {\r",
                  "    pm.expect(pm.response.text()).to.not.be.empty;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"id\": \"gato\",\r\n  \"name\": 4321\r\n}"
