    {
      "name": "Testes Inválidos",
      "item": [
        {
          "name": "TC-011 - Buscar pet com ID inválido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TC-011 - Validar status de erro\r",
                  "pm.test(\"Deve retornar erro para ID inválido\", function () {\r",
                  "    pm.response.to.have.status(404);\r",
                  "});\r",
                  "\r",
                  "// Validar se existe mensagem de erro\r",
                  "pm.test(\"Deve conter mensagem de erro\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.message).to.not.be.empty;\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/pet/{{pet_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "pet",
                "{{pet_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "TC-012 - Validando formato da resposta",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TC-012 - Validação de contrato\r",
                  "pm.test(\"Resposta deve conter estrutura padrão de erro\", function () {\r",
                  "    var resposta = pm.response.json();\r",
                  "    pm.expect(resposta).to.have.all.keys(\"code\", \"type\", \"message\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Campos devem ter tipos corretos\", function () {\r",
                  "    var resposta = pm.response.json();\r",
                  "    pm.expect(resposta.code).to.be.a(\"number\");\r",
                  "    pm.expect(resposta.type).to.be.a(\"string\");\r",
                  "    pm.expect(resposta.message).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Resposta não deve ser sucesso\", function () {\r",
                  "    pm.expect(pm.response.code).to.not.equal(200);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"id\": \"dogs\",\r\n  \"name\": 12\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/pet/{{pet_category}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "pet",
                "{{pet_category}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "TC-013 - Teste de segurança com entrada maliciosa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TC-013 - Teste de segurança\r",
                  "\r",
                  "pm.test(\"API não deve aceitar script malicioso\", function () {\r",
                  "    pm.expect(pm.response.code).to.not.equal(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Deve retornar erro ou sanitizar entrada\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.above(399);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Resposta não deve refletir script diretamente\", function () {\r",
                  "    var resposta = pm.response.text();\r",
                  "    pm.expect(resposta).to.not.include(\"<script>\");\r",
                  "});\r",
                  "\r",
                  "// pm.test(\"API aceita entrada potencialmente maliciosa (comportamento inseguro)\", function () {\r",
                  "//     pm.expect(pm.response.code).to.equal(200);\r",
                  "// });\r",
                  "\r",
                  "// pm.test(\"Resposta contém script não sanitizado (falha de segurança)\", function () {\r",
                  "//     var resposta = pm.response.text();\r",
                  "//     pm.expect(resposta).to.include(\"<script>\");\r",
                  "// });"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"id\": 0,\r\n  \"name\": \"<script>alert('xss')</script>\",\r\n  \"status\": \"available\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
