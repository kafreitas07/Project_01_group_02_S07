      "name": "TC-001 - Criar um novo Pet",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Pet criado corretamente\", () => {\r",
              "    const res = pm.response.json();\r",
              "    pm.expect(res.name).to.eql(\"PetArthur\");\r",
              "});\r",
              "const res = pm.response.json();\r",
              "pm.environment.set(\"petId\", res.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"id\": {{petId}},\r\n  \"name\": \"PetArthur\",\r\n  \"status\": \"available\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/pet",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pet"
          ]
        }
      },
      "response": []
